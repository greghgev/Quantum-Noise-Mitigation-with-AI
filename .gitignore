data/
models/*.pt
models/*.pth
*.onnx

# --- Credenciales y Variables de Entorno (CRÍTICO) ---
.env
.flaskenv
secrets.json
*token*

# --- VS Code & Sistema ---
.vscode/
.DS_Store
Thumbs.db

# --- Windows ADS ---
*:Zone.Identifier


# --- Qiskit / Quantum ---
